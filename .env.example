# Supabase (project: pzxksowuhnfbaqnsmwea)
# CLI token: create at https://supabase.com/dashboard/account/tokens
# Store in repo root .env.local as SUPABASE_ACCESS_TOKEN (gitignored)
SUPABASE_ACCESS_TOKEN=your-supabase-access-token
NEXT_PUBLIC_SUPABASE_URL=https://pzxksowuhnfbaqnsmwea.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
# Legacy names also supported:
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SECRET_KEY=your-secret-key
# SUPABASE_SERVICE_ROLE_KEY=

# Platform admin emails (comma-separated)
PLATFORM_ADMIN_PHONES=9999999999

# Web Push (generate with: npx web-push generate-vapid-keys)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:admin@societymitra.info

# App URL (production)
NEXT_PUBLIC_APP_URL=https://societymitra.info

# Local development override — use in apps/web/.env.local:
# NEXT_PUBLIC_APP_URL=http://localhost:3000
