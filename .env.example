# Supabase (create project in ap-south-1 / Mumbai)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Platform admin emails (comma-separated)
PLATFORM_ADMIN_EMAILS=admin@societymitra.info

# Web Push (generate with: npx web-push generate-vapid-keys)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:admin@societymitra.info

# App URL (production)
NEXT_PUBLIC_APP_URL=https://societymitra.info

# Local development override — use in apps/web/.env.local:
# NEXT_PUBLIC_APP_URL=http://localhost:3000
